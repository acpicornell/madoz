# OCR sources from Internet Archive — large, re-downloadable via fetch_volume.py
data/chocr/
data/page_numbers/
data/txt_djvu/

# Page images (downloaded on demand for phase 3)
data/pages/

# Vision output (regenerable by extract_vision.py — but each rerun has
# a non-trivial dollar cost, so consider committing the final batch
# explicitly when satisfied with quality)
data/vision/

# DuckDB binary — rebuildable from JSONL cache via scrape_madoz.py --from-cache
# and load_chocr_index.py. The raw JSONL is versioned so the DB never needs to
# hit the network to be reconstructed.
db/*.duckdb
db/*.duckdb.wal

# Secrets — never commit. Keep .env.example as the public template.
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Editor
.vscode/
.idea/
.DS_Store
