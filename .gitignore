# OCR sources from Internet Archive — large, re-downloadable via fetch_volume.py
data/chocr/
data/page_numbers/
data/txt_djvu/

# Page images (downloaded on demand for phase 3)
data/pages/
# Resized image cache produced by extract_vision.py for Batch API submits
data/pages_resized/

# Generated audit reports (regenerable from the DB; large files)
data/reports/

# Vision output (regenerable by extract_vision.py — but each rerun has
# a non-trivial dollar cost, so consider committing the final batch
# explicitly when satisfied with quality)
data/vision/

# NGIB pipeline outputs (Mapa tab was removed 2026-05-22 because the
# fuzzy geocoding kept producing wrong placements that were hard to
# audit; the scripts remain dormant under scripts/ but their outputs
# are no longer consumed by the web payload, so we don't track them).
data/ngib/
data/gazetteer.parquet
data/coords.json

# DuckDB binary — rebuildable from JSONL cache via scrape_madoz.py --from-cache
# and load_chocr_index.py. The raw JSONL is versioned so the DB never needs to
# hit the network to be reconstructed.
db/*.duckdb
db/*.duckdb.wal

# Secrets — never commit. Keep .env.example as the public template.
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Editor
.vscode/
.idea/
.DS_Store

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
